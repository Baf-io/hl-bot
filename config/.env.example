# Copy this to .env and fill in — .env is gitignored
HL_WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS
HL_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Start on testnet (true) until live-validated
HL_TESTNET=true

# Strategy toggles — enable one at a time
STRATEGY_FUNDING_CARRY=true
STRATEGY_LEADERBOARD_COPY=true
STRATEGY_CASCADE=true

# Telegram alerts (optional but strongly recommended)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

LOG_LEVEL=INFO
